# NOTE: secrets are managed via Doppler (project=philosopher-pipeline, config=dev).
# Local .env is NOT used. To run: `doppler run -- python pipeline.py --now`
#
# This file exists only to document which keys the pipeline expects
# (so any teammate provisioning a fresh Doppler config knows what to set).

INSTAGRAM_USERNAME=your_instagram_username
INSTAGRAM_PASSWORD=your_instagram_password
GROQ_API_KEY=                                  # currently unused by code, reserved

# Self-improving reel loop (bandit hook picker).
# Phase 1-2 (capture media ids + read delayed insights from the local ledger)
# need NO flag and stay byte-identical until reward data accrues.
# Phase 3 = live instagrapi insights pull. OFF by default; only works on a
# Business/Creator account. Set to 1 to let insights.refresh_pending() run.
PHILOSOPHER_LIVE_INSIGHTS=0
# Bandit exploration rate once reward data exists (optional, default 0.2).
PHILOSOPHER_BANDIT_EPSILON=0.2
